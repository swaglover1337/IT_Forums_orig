<Page x:Class="IT_Forums_orig.EventDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IT_Forums_orig"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="650"
      Title="EventDetailPage"
      Background="#20252b">

    <Grid Margin="20" Background="#d1d3e2">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" 
                VerticalAlignment="Center" Margin="10">
            <StackPanel>
                <Border Height="200" Background="#F0F0F0" CornerRadius="10">
                    <TextBlock Text="Афиша" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                </Border>
                <TextBlock Text="{Binding StartDate, StringFormat='{}Дата начала: {0:dd.MM.yyyy}'}" 
                       Margin="15" FontSize="16" FontWeight="SemiBold"/>
                <Button Content="Назад к списку" Margin="10" Click="BackButton_Click"
                        Style="{StaticResource SimpleButton}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#E0E0E0" CornerRadius="10,10,0,0" Padding="20,10">
                    <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="20">
                    <StackPanel>
                        <TextBlock Text="{Binding Description}" FontSize="18" TextWrapping="Wrap"
                                   Margin="2" Style="{StaticResource TextBlocks}"/>

                        <TextBlock Text="Программа мероприятия" FontSize="20" FontWeight="Bold"
                                   Margin="5" Foreground="#046ddb"
                                   Style="{StaticResource TextBlocks}"/>

                        <ItemsControl ItemsSource="{Binding Session}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9F9F9" Margin="0,0,0,10" Padding="15" CornerRadius="8" BorderBrush="#DDD" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding EndTime, StringFormat='{}— {0:HH:mm}'}" FontSize="14" Foreground="Gray"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="15">
                                                <TextBlock Text="{Binding Theme}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock Text="📍 " FontSize="13"/>
                                                    <TextBlock Text="{Binding Location.Location1}" FontSize="13" Foreground="DimGray" FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding Location.Room, StringFormat=' (каб. {0})'}" FontSize="13" Foreground="DimGray"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</Page>
