<Page x:Class="IT_Forums_orig.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IT_Forums_orig"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegistrationPage" Loaded="Page_Loaded">

    <Grid Margin="20" Background="#d1d3e2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="10" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Регистрация нового участника" Style="{StaticResource TextBlocks}"
                           FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2e59d9"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,10,0">

                        <TextBlock Text="Выберите мероприятие:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ComboEvents" Height="40" DisplayMemberPath="Name" Margin="0,0,0,15" FontSize="16" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Фамилия:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtLastName" Style="{StaticResource TextBoxes}" Height="40" FontSize="16" Margin="0,0,0,15"/>

                        <TextBlock Text="Имя:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtName" Style="{StaticResource TextBoxes}" Height="40" FontSize="16" Margin="0,0,0,15"/>

                        <TextBlock Text="Отчество:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtMiddleName" Style="{StaticResource TextBoxes}" Height="40" FontSize="16" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Телефон:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtPhone" Style="{StaticResource TextBoxes}" Height="40" FontSize="16"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Email:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtEmail" Style="{StaticResource TextBoxes}" Height="40" FontSize="16"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Группа / Категория:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                                <ComboBox x:Name="ComboGroups" Height="40" DisplayMemberPath="Type" FontSize="16" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Тип билета:" FontSize="13" Foreground="Gray" Margin="0,0,0,5"/>
                                <ComboBox x:Name="ComboTickets" Height="40" DisplayMemberPath="Type" FontSize="16" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Зарегистрировать" Height="50" 
                        Background="#4e73df" Foreground="White" FontSize="18" 
                        FontWeight="Bold" Margin="0,15,0,0" Click="BtnRegister_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="10" Padding="20">
            <Grid>
                <StackPanel x:Name="PanelPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                    <TextBlock Text="Информация" FontSize="20" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                </StackPanel>

                <Grid x:Name="PanelEventDetails" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="160" Background="#f8f9fc" BorderBrush="#eaecf4" BorderThickness="2" CornerRadius="8" Margin="0,0,0,20">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🎨" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Афиша мероприятия" FontSize="14" FontWeight="Bold" Foreground="#4e73df" HorizontalAlignment="Center"/>
                                <TextBlock Text="(Изображение не загружено)" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <TextBlock x:Name="TxtInfoTitle" Text="Название форума" FontSize="20" FontWeight="Bold" Foreground="#2e59d9" TextWrapping="Wrap" Margin="0,0,0,15"/>

                        <Separator Background="#eaecf4" Margin="0,0,0,15"/>

                        <TextBlock Text="📅 Дата проведения:" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtInfoDate" Text="10 мая 2026" FontSize="16" FontWeight="SemiBold" Foreground="#4fafdf" Margin="0,0,0,12"/>

                        <TextBlock Text="📍 Место проведения:" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtInfoLocation" Text="Главный зал корпуса А" FontSize="16" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <TextBlock Text="👤 Ответственное лицо:" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtInfoResponsible" Text="Иванов И.И." FontSize="16" Foreground="#333333" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
