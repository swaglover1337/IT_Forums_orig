<Page x:Class="IT_Forums_orig.MainLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IT_Forums_orig"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="650"
      Title="MainLayout" Background="#20252b">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Background="#20252b"/>
        <StackPanel Grid.Column="0" Background="#20252b" x:Name="SidePanel"
                    VerticalAlignment="Center">
            <Image Source="/Resources/logo.png" Margin="20"/>
            <Button Content="Мероприятия" Margin="5" Height="40"
                    Style="{StaticResource SimpleButton}" Click="Events_Click"/>
            <Button Content="Управление" Margin="5" Height="40"
                    Style="{StaticResource SimpleButton}" Click="EditEvent_Click"/>
            <Button Content="Программы" Margin="5" Height="40"
                    Style="{StaticResource SimpleButton}" Click="Programs_Click"/>
            <Button Content="Регистрация" Margin="5" Height="40"
                    Style="{StaticResource SimpleButton}" Click="Reg_Click"/>
            <Button Content="Участники" Margin="5" Height="40"
                    Style="{StaticResource SimpleButton}" Click="Members_Click"/>
            <Button Content="Выход" Margin="10,20" 
                    Style="{StaticResource MainButton}"/>
        </StackPanel>

        <Frame x:Name="InnerFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="10"/>

    </Grid>
</Page>
