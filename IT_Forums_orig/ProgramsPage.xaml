<Page x:Class="IT_Forums_orig.ProgramsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IT_Forums_orig"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProgramsPage">

    <Grid Margin="20" Background="#d1d3e2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10" Margin="10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Выберите мероприятие:" Style="{StaticResource TextBlocks}"
                           FontSize="20" FontWeight="Bold" Margin="10" Foreground="#046ddb"/>

                <ListBox Grid.Row="1" x:Name="ComboEvents" FontSize="20"
                         DisplayMemberPath="Name" 
                         SelectionChanged="ComboEvents_SelectionChanged"
                         BorderThickness="0" Background="Transparent"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="10" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Управление сессиями программы" Style="{StaticResource TextBlocks}"
                               FontWeight="Bold" Margin="10" VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Content="+ Добавить сессию" 
                            Background="#7be100" Foreground="White" FontWeight="Bold"
                            Style="{StaticResource SimpleButton}"
                            Padding="5" Height="35" Click="BtnAddSession_Click"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SessionsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F9F9F9" Margin="10" Padding="10" 
                                        CornerRadius="8" BorderBrush="#CCC" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Row="0" Grid.Column="2" Content="❌"
                                                Foreground="#fc3014" BorderThickness="0" Background="Transparent"
                                                FontSize="14" VerticalAlignment="Top" Cursor="Hand"
                                                Margin="5" Click="BtnDeleteSession_Click"/>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Тема сессии:" FontSize="12" Foreground="Gray"/>
                                            <TextBox Text="{Binding Theme, Mode=TwoWay}" 
                                                     Style="{StaticResource TextBoxes}" Height="35"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="Локация/Зал:" FontSize="12" Foreground="Gray"/>
                                            <ComboBox SelectedValue="{Binding Loc_ID, Mode=TwoWay}" 
                                                      SelectedValuePath="Loc_ID" 
                                                      DisplayMemberPath="Location1"
                                                      x:Name="ComboLocations"
                                                      Loaded="ComboLocations_Loaded" Height="35"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,0">
                                            <StackPanel Width="150" Margin="0,0,10,0">
                                                <TextBlock Text="Начало:" FontSize="12" Foreground="Gray"/>
                                                <TextBox Text="{Binding StartTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=TwoWay}" 
                                                         Style="{StaticResource TextBoxes}" 
                                                         FontSize="18" Height="35"/>
                                            </StackPanel>

                                            <StackPanel Width="150">
                                                <TextBlock Text="Окончание:" FontSize="12" Foreground="Gray"/>
                                                <TextBox Text="{Binding EndTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=TwoWay}"
                                                         Style="{StaticResource TextBoxes}" 
                                                         FontSize="18" Height="35"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Сохранить изменения программы" 
                        Style="{StaticResource MainButton}"
                        Height="45" Background="#046ddb" Foreground="White" 
                        FontWeight="Bold" Margin="15" Click="BtnSaveChanges_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
