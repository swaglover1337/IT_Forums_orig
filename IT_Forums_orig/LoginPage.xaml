<Page x:Class="IT_Forums_orig.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IT_Forums_orig"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="650"
      Title="LoginPage"
      Background="#20252b">

    <Grid Margin="20" Background="#d1d3e2">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/Resources/logo.png"
               Margin="2"/>

        <TextBlock Text="Вход в систему IT-Форум"
                   Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
           Style="{StaticResource HeaderTextStyle}"/>

        <TextBlock Text="Логин: "
                   Grid.Row="1" Margin="10"
                   VerticalAlignment="Center" HorizontalAlignment="Right"
                   Style="{StaticResource TextBlocks}"/>
        <TextBlock Text="Пароль: "
                   Grid.Row="2" Margin="10"
           VerticalAlignment="Center" HorizontalAlignment="Right"
           Style="{StaticResource TextBlocks}"/>

        <TextBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                 Margin="20" MaxHeight="100" MaxWidth="1000"
                 Style="{StaticResource TextBoxes}"/>
        <TextBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2"
                 Margin="20" MaxHeight="100" MaxWidth="1000"
                 Style="{StaticResource TextBoxes}"/>


        <Button Content="Войти в систему"
                Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                Width="250" Margin="20" MaxHeight="100"
                Style="{StaticResource MainButton}"
                Click="Vhod_Click"/>

    </Grid>
</Page>
